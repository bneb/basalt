// =============================================================================
// Basalt — Inference Engine Entry Point
// =============================================================================

package main

import std.io.println
import std.core.ptr.Ptr

import basalt.transformer.{Config, TransformerWeights, RunState, alloc_run_state, free_run_state, forward}
import basalt.kernels.softmax
import basalt.sampler.{sample_argmax, sample_token, sample_topp}
import basalt.model_loader.{load_config, get_weights, get_weights_q8, is_model_q8}
import basalt.tokenizer.{Tokenizer, load_tokenizer, decode_token, decode_token_len}

// -----------------------------------------------------------------------------
// Externs (libc / runtime)
// -----------------------------------------------------------------------------

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);
extern fn cosf(x: f32) -> f32;
extern fn sinf(x: f32) -> f32;
extern fn powf(base: f32, exp: f32) -> f32;

extern fn salt_get_argc() -> i32;
extern fn salt_get_argv(idx: i32) -> Ptr<u8>;

// Pre-tokenized prompt (set by JS, stored in C globals)
extern fn salt_get_prompt_count() -> i64;
extern fn salt_get_prompt_token(idx: i64) -> i64;

extern fn open(path: Ptr<u8>, flags: i32) -> i32;
extern fn mmap(addr: Ptr<u8>, len: u64, prot: i32, flags: i32, fd: i32, offset: i64) -> Ptr<u8>;
extern fn close(fd: i32) -> i32;

// Write raw bytes to stdout (for printing token text without newline)
extern fn write(fd: i32, buf: Ptr<u8>, count: i64) -> i64;

// Monotonic nanosecond clock (from runtime.c)
extern fn salt_clock_now() -> i64;

// -----------------------------------------------------------------------------
// Precompute RoPE
// -----------------------------------------------------------------------------

fn build_freq_cis(cfg: &Config) -> TransformerWeights {
    let head_size = cfg.dim / cfg.n_heads;
    let n_elem = cfg.seq_len * (head_size / 2);
    
    let real_ptr = malloc(n_elem * 4) as Ptr<f32>;
    let imag_ptr = malloc(n_elem * 4) as Ptr<f32>;
    
    if real_ptr as i64 == 0 || imag_ptr as i64 == 0 {
        if real_ptr as i64 != 0 { free(real_ptr as Ptr<u8>); }
        if imag_ptr as i64 != 0 { free(imag_ptr as Ptr<u8>); }
        return TransformerWeights {
            token_embedding_table: 0 as Ptr<f32>, rms_att_weight: 0 as Ptr<f32>,
            wq: 0 as Ptr<f32>, wk: 0 as Ptr<f32>, wv: 0 as Ptr<f32>, wo: 0 as Ptr<f32>,
            rms_ffn_weight: 0 as Ptr<f32>, w1: 0 as Ptr<f32>, w2: 0 as Ptr<f32>, w3: 0 as Ptr<f32>,
            rms_final_weight: 0 as Ptr<f32>, w_cls: 0 as Ptr<f32>,
            freq_cis_real: 0 as Ptr<f32>,
            freq_cis_imag: 0 as Ptr<f32>
        };
    }
    
    for pos in 0..cfg.seq_len {
        for i in 0..(head_size / 2) {
            let exponent = (i as f32 * 2.0f32) / (head_size as f32);
            let freq = 1.0f32 / powf(10000.0f32, exponent);
            let val = pos as f32 * freq;
            
            let idx = pos * (head_size / 2) + i;
            real_ptr[idx] = cosf(val);
            imag_ptr[idx] = sinf(val);
        }
    }
    
    return TransformerWeights {
        token_embedding_table: 0 as Ptr<f32>, rms_att_weight: 0 as Ptr<f32>,
        wq: 0 as Ptr<f32>, wk: 0 as Ptr<f32>, wv: 0 as Ptr<f32>, wo: 0 as Ptr<f32>,
        rms_ffn_weight: 0 as Ptr<f32>, w1: 0 as Ptr<f32>, w2: 0 as Ptr<f32>, w3: 0 as Ptr<f32>,
        rms_final_weight: 0 as Ptr<f32>, w_cls: 0 as Ptr<f32>,
        freq_cis_real: real_ptr,
        freq_cis_imag: imag_ptr
    };
}

// -----------------------------------------------------------------------------
// File Helpers
// -----------------------------------------------------------------------------

extern fn lseek(fd: i32, offset: i64, whence: i32) -> i64;

fn mmap_file(path: Ptr<u8>) -> Ptr<u8> {
    let fd = open(path, 0); // O_RDONLY
    if fd < 0 {
        return 0 as Ptr<u8>;
    }
    
    // SEEK_END=2 to get file size, SEEK_SET=0 to rewind
    let size = lseek(fd, 0, 2);
    lseek(fd, 0, 0);
    
    if size <= 0 {
        close(fd);
        return 0 as Ptr<u8>;
    }

    // PROT_READ=1, MAP_PRIVATE=2
    let data = mmap(0 as Ptr<u8>, size as u64, 1, 2, fd, 0);
    let data_addr = data as i64;
    if data_addr == -1 {
        close(fd);
        return 0 as Ptr<u8>;
    }
    return data;
}

// -----------------------------------------------------------------------------
// Logic
// -----------------------------------------------------------------------------

fn run_mock() -> i32 {
    println("Running in MOCK mode (no model file provided).");
    let cfg = Config {
        dim: 256, hidden_dim: 512, n_layers: 4, n_heads: 8, n_kv_heads: 8,
        vocab_size: 1000, seq_len: 128,
    };
    
    let state = alloc_run_state(&cfg);
    
    let dummy_bytes: i64 = 128 * 1024 * 1024;
    let dummy_ptr: Ptr<u8> = malloc(dummy_bytes);
    if dummy_ptr as i64 == 0 {
        return 1;
    }
    let dummy_float: Ptr<f32> = dummy_ptr as Ptr<f32>;

    let w = TransformerWeights {
        token_embedding_table: dummy_float, rms_att_weight: dummy_float,
        wq: dummy_float, wk: dummy_float, wv: dummy_float, wo: dummy_float,
        rms_ffn_weight: dummy_float, w1: dummy_float, w2: dummy_float, w3: dummy_float,
        rms_final_weight: dummy_float, freq_cis_real: dummy_float, freq_cis_imag: dummy_float,
        w_cls: dummy_float,
    };

    forward(&cfg, &w, &state, 1, 0);
    let next_token = sample_argmax(state.logits, cfg.vocab_size);
    println("Sampled token: {}", next_token);
    
    free(dummy_ptr);
    free_run_state(state);
    return 0;
}

fn generate_tokens(cfg: &Config, w: &TransformerWeights, state: &RunState, tok: &Tokenizer, steps: i64, n_prompt_tokens: i64) -> i64 {
    let mut token: i64 = 1;
    let mut pos: i64 = 0;
    
    let t_start = salt_clock_now();
    for pi in 0..n_prompt_tokens {
        forward(cfg, w, state, token, pos);
        token = salt_get_prompt_token(pi);
        pos = pos + 1;
    }
    
    for gp in pos..steps {
        forward(cfg, w, state, token, gp);
        token = sample_argmax(state.logits, cfg.vocab_size);
        
        if tok.vocab_size > 0 {
            let text = decode_token(tok[0], token);
            let text_len = decode_token_len(tok[0], token);
            write(1, text, text_len as i64);
        }
    }
    return salt_clock_now() - t_start;
}

fn run_inference(model_path: Ptr<u8>, tok_path: Ptr<u8>) -> i32 {
    println("Loading model...");
    let model_data = mmap_file(model_path);
    if (model_data as i64) == 0 { println("Failed to open model file."); return 1; }
    
    let cfg = load_config(model_data);
    let q8: i32 = is_model_q8(model_data);
    println("Config: dim={}, layers={}, heads={}, vocab={}", cfg.dim, cfg.n_layers, cfg.n_heads, cfg.vocab_size);
    if q8 == 1 { println("Model format: q8_0"); }
    
    let mut w = if q8 == 1 { get_weights_q8(model_data, &cfg) } else { get_weights(model_data, &cfg) };
    let rope_w = build_freq_cis(&cfg);
    w.freq_cis_real = rope_w.freq_cis_real; w.freq_cis_imag = rope_w.freq_cis_imag;
    
    let tok_data = mmap_file(tok_path);
    let mut tok = Tokenizer { vocab: 0 as Ptr<TokenizerEntry>, vocab_size: 0, max_token_length: 0, text_arena: 0 as Ptr<u8>, special_tokens: 0 as Ptr<SpecialToken>, n_special: 0, special_capacity: 0, token_hash: 0 as Ptr<i64>, hash_size: 0 };
    if (tok_data as i64) != 0 {
        tok = load_tokenizer(tok_data, cfg.vocab_size);
        println("Tokenizer loaded ({} entries).", tok.vocab_size);
    }
    
    let n_prompt_tokens = salt_get_prompt_count();
    println("Prompt tokens: {}", n_prompt_tokens);
    let state = alloc_run_state(&cfg);
    let steps: i64 = cfg.seq_len;
    println("Generating {} tokens...", steps);
    
    let elapsed_ns = generate_tokens(&cfg, &w, &state, &tok, steps, n_prompt_tokens);
    
    let elapsed_ms = elapsed_ns / 1000000;
    let toks_per_sec = (steps * 1000000000) / elapsed_ns;
    println("\n---\ntokens: {}\nelapsed: {}ms\ntok/s: {}", steps, elapsed_ms, toks_per_sec);
    
    free_run_state(state);
    if rope_w.freq_cis_real as i64 != 0 { free(rope_w.freq_cis_real as Ptr<u8>); }
    if rope_w.freq_cis_imag as i64 != 0 { free(rope_w.freq_cis_imag as Ptr<u8>); }
    return 0;
}

fn main() -> i32 {
    println("Basalt v0.5.0 (Llama 2 Inference)");
    
    let argc = salt_get_argc();
    if argc < 2 {
        return run_mock();
    }
    
    let model_path = salt_get_argv(1);
    
    let mut tok_path: Ptr<u8> = 0 as Ptr<u8>;
    if argc >= 3 {
        tok_path = salt_get_argv(2);
    }
    
    // ── Prevent DCE for WASM exports ────────────────────────────────────────
    // These are never called (argc = 999), but referencing them ensures
    // the compiler and DCE passes keep them alive for the WASM build.
    if argc == 999 {
        let es = basalt_engine_init(0 as Ptr<u8>, 0);
        basalt_engine_ingest_prompt(es, 0 as Ptr<i64>, 0);
        let _t = basalt_engine_generate_step(es);
        let _c = basalt_engine_get_config(es, 0);
        basalt_engine_set_sampling(es, 0.0f32, 0.0f32, 0);
        basalt_engine_reset(es);
        basalt_engine_free(es);
    }
    // ────────────────────────────────────────────────────────────────────────
    
    return run_inference(model_path, tok_path);
}

// =============================================================================
// WASM Engine API — Brutalist 6+1 Exports
// =============================================================================
//
// Direct struct access enabled by Salt compiler fixes:
//   - `var` globals replace C accessor functions
//   - `Ptr<EngineState>` replaces flat Ptr<i64> buffer
//   - Nested struct field access (es.config.dim) replaces serialize/deserialize
//
// =============================================================================

// ── Engine State ────────────────────────────────────────────────────────────

struct EngineState {
    config: Config,
    weights: TransformerWeights,
    state: RunState,
    pos: i64,
    token: i64,
    initialized: i32,
    temperature: f32,
    topp: f32,
    rng_state: i64,
}

pub fn basalt_engine_init(model_data: Ptr<u8>, model_size: i64) -> Ptr<EngineState> {
    let cfg = load_config(model_data);
    let q8: i32 = is_model_q8(model_data);
    let mut w = if q8 == 1 {
        get_weights_q8(model_data, &cfg)
    } else {
        get_weights(model_data, &cfg)
    };
    let rope_w = build_freq_cis(&cfg);
    w.freq_cis_real = rope_w.freq_cis_real;
    w.freq_cis_imag = rope_w.freq_cis_imag;
    
    let es_ptr = malloc(1024) as Ptr<EngineState>;
    if es_ptr as i64 == 0 {
        if rope_w.freq_cis_real as i64 != 0 { free(rope_w.freq_cis_real as Ptr<u8>); }
        if rope_w.freq_cis_imag as i64 != 0 { free(rope_w.freq_cis_imag as Ptr<u8>); }
        return 0 as Ptr<EngineState>;
    }
    
    es_ptr.config = cfg;
    es_ptr.weights = w;
    let run_state = alloc_run_state(&cfg);
    if run_state.x as i64 == 0 {
        free(es_ptr as Ptr<u8>);
        if rope_w.freq_cis_real as i64 != 0 { free(rope_w.freq_cis_real as Ptr<u8>); }
        if rope_w.freq_cis_imag as i64 != 0 { free(rope_w.freq_cis_imag as Ptr<u8>); }
        return 0 as Ptr<EngineState>;
    }
    es_ptr.state = run_state;
    es_ptr.pos = 0;
    es_ptr.token = 1;
    es_ptr.initialized = 1;
    es_ptr.temperature = 0.0f32;
    es_ptr.topp = 0.9f32;
    es_ptr.rng_state = 42;
    
    return es_ptr;
}

// ── Unified config getter ───────────────────────────────────────────────────

pub fn basalt_engine_get_config(es_ptr: Ptr<EngineState>, param_id: i64) -> i64 {
    if es_ptr.initialized == 0 { return -1; }
    let cfg = es_ptr.config;
    
    if param_id == 0 { return cfg.dim; }
    if param_id == 1 { return cfg.hidden_dim; }
    if param_id == 2 { return cfg.n_layers; }
    if param_id == 3 { return cfg.n_heads; }
    if param_id == 4 { return cfg.n_kv_heads; }
    if param_id == 5 { return cfg.vocab_size; }
    if param_id == 6 { return cfg.seq_len; }
    return -1;
}

// ── Step functions ──────────────────────────────────────────────────────────

pub fn basalt_engine_prefill(es_ptr: Ptr<EngineState>, token_id: i64) {
    if es_ptr.initialized == 0 { return; }

    let mut tmp_cfg = es_ptr.config;
    let mut tmp_w = es_ptr.weights;
    let mut tmp_state = es_ptr.state;
    forward(&tmp_cfg, &tmp_w, &tmp_state, es_ptr.token, es_ptr.pos);
    es_ptr.token = token_id;
    es_ptr.pos = es_ptr.pos + 1;
}

pub fn basalt_engine_generate_step(es_ptr: Ptr<EngineState>) -> i64 {
    if es_ptr.initialized == 0 { return -1; }
    
    let cfg = es_ptr.config;
    if es_ptr.pos >= cfg.seq_len { return -1; }

    let mut tmp_w = es_ptr.weights;
    let mut tmp_state = es_ptr.state;
    forward(&cfg, &tmp_w, &tmp_state, es_ptr.token, es_ptr.pos);

    // ── Sampling: temperature → softmax → sample ────────────────────────
    let logits: Ptr<f32> = es_ptr.state.logits;
    let vocab: i64 = cfg.vocab_size;
    let temp: f32 = es_ptr.temperature;

    let mut next: i64 = 0;

    if temp <= 0.0f32 {
        // Greedy: deterministic argmax (temperature = 0)
        next = sample_argmax(logits, vocab);
    } else {
        // Scale logits by 1/temperature, then softmax
        for i in 0..vocab {
            logits[i] = logits[i] / temp;
        }
        softmax(logits, vocab);

        // Generate random coin via xoshiro128+
        let mut s: i64 = es_ptr.rng_state;
        s = s ^ (s << 13);
        s = s ^ (s >> 7);
        s = s ^ (s << 17);
        es_ptr.rng_state = s;
        // Map to [0, 1): take lower 31 bits, divide by 2^31
        let coin_bits: i64 = s & 2147483647;
        let coin: f32 = (coin_bits as f32) / 2147483648.0f32;

        let tp: f32 = es_ptr.topp;
        if tp > 0.0f32 {
            if tp < 1.0f32 {
                next = sample_topp(logits, vocab, tp, coin);
            } else {
                next = sample_token(logits, vocab, coin);
            }
        } else {
            next = sample_token(logits, vocab, coin);
        }
    }

    es_ptr.token = next;
    es_ptr.pos = es_ptr.pos + 1;

    return next;
}

// ── Set sampling parameters ────────────────────────────────────────────────

pub fn basalt_engine_set_sampling(es_ptr: Ptr<EngineState>, temp: f32, topp: f32, seed: i64) {
    if es_ptr.initialized == 0 { return; }
    es_ptr.temperature = temp;
    es_ptr.topp = topp;
    if seed != 0 {
        es_ptr.rng_state = seed;
    }
}

pub fn basalt_engine_free(es_ptr: Ptr<EngineState>) {
    if es_ptr.initialized == 0 { return; }
    free_run_state(es_ptr.state);
    
    let w = es_ptr.weights;
    if w.freq_cis_real as i64 != 0 {
        free(w.freq_cis_real as Ptr<u8>);
    }
    if w.freq_cis_imag as i64 != 0 {
        free(w.freq_cis_imag as Ptr<u8>);
    }

    // [NEW-02] SECURITY FIX: Use-after-free — must zero the sentinel BEFORE
    // freeing the struct, not after. Writing to freed memory is undefined behavior.
    es_ptr.initialized = 0;
    free(es_ptr as Ptr<u8>);
}

// ── Reset (multi-turn chat: clear KV cache, keep weights) ──────────────────

pub fn basalt_engine_reset(es_ptr: Ptr<EngineState>) {
    if es_ptr.initialized == 0 { return; }

    // No need to manually zero out the KV cache (key_cache and value_cache) 
    // since it gets overwritten sequentially based on `pos`.
    es_ptr.pos = 0;
    es_ptr.token = 1;
}

// ── Bulk prefill (1 boundary crossing for entire prompt) ────────────────────

pub fn basalt_engine_ingest_prompt(es_ptr: Ptr<EngineState>, tokens_ptr: Ptr<i64>, count: i64) {
    if es_ptr.initialized == 0 { return; }
    if count <= 0 { return; }

    let cfg = es_ptr.config;

    for i in 0..count {
        if es_ptr.pos >= cfg.seq_len { return; }
        let mut tmp_w = es_ptr.weights;
    let mut tmp_state = es_ptr.state;
    forward(&cfg, &tmp_w, &tmp_state, es_ptr.token, es_ptr.pos);
        es_ptr.token = tokens_ptr[i];
        es_ptr.pos = es_ptr.pos + 1;
    }
}

// ── Legacy getters (kept for native build compatibility) ─────────────────────

pub fn basalt_engine_get_dim(es_ptr: Ptr<EngineState>) -> i64 {
    return basalt_engine_get_config(es_ptr, 0);
}

pub fn basalt_engine_get_vocab_size(es_ptr: Ptr<EngineState>) -> i64 {
    return basalt_engine_get_config(es_ptr, 5);
}

pub fn basalt_engine_get_seq_len(es_ptr: Ptr<EngineState>) -> i64 {
    return basalt_engine_get_config(es_ptr, 6);
}

pub fn basalt_engine_get_n_layers(es_ptr: Ptr<EngineState>) -> i64 {
    return basalt_engine_get_config(es_ptr, 2);
}

