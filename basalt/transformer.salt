// =============================================================================
// Basalt Transformer — Llama 2 Architecture
// =============================================================================
//
// Defines the Config, Weights, and RunState structs.
// Implements the forward pass orchestrating the compute kernels.
//
// =============================================================================

package basalt.transformer

import std.core.ptr.Ptr
import basalt.kernels.{rmsnorm, softmax, mat_mul}
import basalt.quant.{mat_mul_vec_q8, dequant_block_q8}

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);
extern fn expf(x: f32) -> f32;
extern fn sqrtf(x: f32) -> f32;

// -----------------------------------------------------------------------------
// Configuration
// -----------------------------------------------------------------------------
pub struct Config {
    pub dim: i64,        // Transformer dimension
    pub hidden_dim: i64, // FFN hidden dimension
    pub n_layers: i64,   // Number of layers
    pub n_heads: i64,    // Number of query heads
    pub n_kv_heads: i64, // Number of key/value heads (can be < n_heads)
    pub vocab_size: i64, // Vocabulary size
    pub seq_len: i64,    // Max sequence length
}

// -----------------------------------------------------------------------------
// Weights (Mmap View)
// -----------------------------------------------------------------------------
pub struct TransformerWeights {
    pub token_embedding_table: Ptr<f32>, // (vocab_size, dim) — always f32
    
    pub rms_att_weight: Ptr<f32>, // (layer, dim) — always f32
    pub wq: Ptr<f32>,             // (layer, dim, n_heads * head_size)
    pub wk: Ptr<f32>,             // (layer, dim, n_kv_heads * head_size)
    pub wv: Ptr<f32>,             // (layer, dim, n_kv_heads * head_size)
    pub wo: Ptr<f32>,             // (layer, n_heads * head_size, dim)
    
    pub rms_ffn_weight: Ptr<f32>, // (layer, dim) — always f32
    pub w1: Ptr<f32>,             // (layer, dim, hidden_dim)
    pub w2: Ptr<f32>,             // (layer, hidden_dim, dim)
    pub w3: Ptr<f32>,             // (layer, dim, hidden_dim)
    
    pub rms_final_weight: Ptr<f32>, // (dim) — always f32
    
    pub freq_cis_real: Ptr<f32>, // (seq_len, dim/2)
    pub freq_cis_imag: Ptr<f32>, // (seq_len, dim/2)
    
    pub w_cls: Ptr<f32>, // (dim, vocab_size)
    
    // q8_0 quantized weight pointers (null when using f32)
    pub wq_q8: Ptr<u8>,
    pub wk_q8: Ptr<u8>,
    pub wv_q8: Ptr<u8>,
    pub wo_q8: Ptr<u8>,
    pub w1_q8: Ptr<u8>,
    pub w2_q8: Ptr<u8>,
    pub w3_q8: Ptr<u8>,
    pub w_cls_q8: Ptr<u8>,
    pub embed_q8: Ptr<u8>,      // token embedding in q8_0 (on-the-fly dequant)
    
    pub is_q8: i32,  // 1 if quantized, 0 if f32
}

// -----------------------------------------------------------------------------
// RunState (Activation Buffers)
// -----------------------------------------------------------------------------
pub struct RunState {
    pub x: Ptr<f32>,      // (dim)
    pub xb: Ptr<f32>,     // (dim)
    pub xb2: Ptr<f32>,    // (dim)
    pub hb: Ptr<f32>,     // (hidden_dim)
    pub hb2: Ptr<f32>,    // (hidden_dim)
    
    pub q: Ptr<f32>,      // (dim)
    pub k: Ptr<f32>,      // (dim)
    pub v: Ptr<f32>,      // (dim)
    pub att: Ptr<f32>,    // (n_heads, seq_len)
    
    pub logits: Ptr<f32>, // (vocab_size)
    
    pub key_cache: Ptr<f32>,   // (layer, seq_len, dim)
    pub value_cache: Ptr<f32>, // (layer, seq_len, dim)
}

// -----------------------------------------------------------------------------
// Initialization
// -----------------------------------------------------------------------------

fn alloc_f32(count: i64) -> Ptr<f32> {
    let ptr: Ptr<u8> = malloc(count * 4);
    if ptr as i64 == 0 {
        return 0 as Ptr<f32>;
    }
    return ptr as Ptr<f32>;
}

pub fn alloc_run_state(cfg: Config) -> RunState {
    let kw_dim: i64 = (cfg.dim * cfg.n_kv_heads) / cfg.n_heads;
    
    let x = alloc_f32(cfg.dim);
    let xb = alloc_f32(cfg.dim);
    let xb2 = alloc_f32(cfg.dim);
    let hb = alloc_f32(cfg.hidden_dim);
    let hb2 = alloc_f32(cfg.hidden_dim);
    let q = alloc_f32(cfg.dim);
    let k = alloc_f32(kw_dim);
    let v = alloc_f32(kw_dim);
    let att = alloc_f32(cfg.n_heads * cfg.seq_len);
    let logits = alloc_f32(cfg.vocab_size);
    let key_cache = alloc_f32(cfg.n_layers * cfg.seq_len * kw_dim);
    let value_cache = alloc_f32(cfg.n_layers * cfg.seq_len * kw_dim);

    if x as i64 == 0 || xb as i64 == 0 || xb2 as i64 == 0 || hb as i64 == 0 || hb2 as i64 == 0 ||
       q as i64 == 0 || k as i64 == 0 || v as i64 == 0 || att as i64 == 0 || logits as i64 == 0 ||
       key_cache as i64 == 0 || value_cache as i64 == 0 {
        if x as i64 != 0 { free(x as Ptr<u8>); }
        if xb as i64 != 0 { free(xb as Ptr<u8>); }
        if xb2 as i64 != 0 { free(xb2 as Ptr<u8>); }
        if hb as i64 != 0 { free(hb as Ptr<u8>); }
        if hb2 as i64 != 0 { free(hb2 as Ptr<u8>); }
        if q as i64 != 0 { free(q as Ptr<u8>); }
        if k as i64 != 0 { free(k as Ptr<u8>); }
        if v as i64 != 0 { free(v as Ptr<u8>); }
        if att as i64 != 0 { free(att as Ptr<u8>); }
        if logits as i64 != 0 { free(logits as Ptr<u8>); }
        if key_cache as i64 != 0 { free(key_cache as Ptr<u8>); }
        if value_cache as i64 != 0 { free(value_cache as Ptr<u8>); }
        return RunState {
            x: 0 as Ptr<f32>, xb: 0 as Ptr<f32>, xb2: 0 as Ptr<f32>, hb: 0 as Ptr<f32>, hb2: 0 as Ptr<f32>,
            q: 0 as Ptr<f32>, k: 0 as Ptr<f32>, v: 0 as Ptr<f32>, att: 0 as Ptr<f32>, logits: 0 as Ptr<f32>,
            key_cache: 0 as Ptr<f32>, value_cache: 0 as Ptr<f32>,
        };
    }
    
    return RunState {
        x: x, xb: xb, xb2: xb2, hb: hb, hb2: hb2,
        q: q, k: k, v: v, att: att, logits: logits,
        key_cache: key_cache, value_cache: value_cache,
    };
}

pub fn free_run_state(s: RunState) {
    free(s.x as Ptr<u8>);
    free(s.xb as Ptr<u8>);
    free(s.xb2 as Ptr<u8>);
    free(s.hb as Ptr<u8>);
    free(s.hb2 as Ptr<u8>);
    free(s.q as Ptr<u8>);
    free(s.k as Ptr<u8>);
    free(s.v as Ptr<u8>);
    free(s.att as Ptr<u8>);
    free(s.logits as Ptr<u8>);
    free(s.key_cache as Ptr<u8>);
    free(s.value_cache as Ptr<u8>);
}

// -----------------------------------------------------------------------------
// Forward Pass
// -----------------------------------------------------------------------------

fn transformer_embedding(s: &RunState, w: &TransformerWeights, dim: i64, token: i64) {
    unsafe {
        if w.is_q8 == 1 {
            let row_bytes: i64 = (dim / 32) * 34;
            let row_ptr = w.embed_q8.offset(token * row_bytes);
            dequant_block_q8(row_ptr, s.x, dim / 32);
        } else {
            let embed_row = w.token_embedding_table;
            let offset: i64 = token * dim;
            for i in 0..dim {
                s.x[i] = embed_row[offset + i];
            }
        }
    }
}

fn project_qkv(s: &RunState, w: &TransformerWeights, dim: i64, kv_dim: i64, l: i64) {
    unsafe {
        let wq_offset: i64 = l * dim * dim;
        let wk_offset: i64 = l * kv_dim * dim;
        let wv_offset: i64 = l * kv_dim * dim;
        
        if w.is_q8 == 1 {
            let wq_q8_off: i64 = l * dim * (dim / 32) * 34;
            let wk_q8_off: i64 = l * kv_dim * (dim / 32) * 34;
            let wv_q8_off: i64 = l * kv_dim * (dim / 32) * 34;
            mat_mul_vec_q8(s.q, w.wq_q8.offset(wq_q8_off), s.xb, dim, dim);
            mat_mul_vec_q8(s.k, w.wk_q8.offset(wk_q8_off), s.xb, kv_dim, dim);
            mat_mul_vec_q8(s.v, w.wv_q8.offset(wv_q8_off), s.xb, kv_dim, dim);
        } else {
            mat_mul(s.q, w.wq.offset(wq_offset), s.xb, dim, 1, dim);
            mat_mul(s.k, w.wk.offset(wk_offset), s.xb, kv_dim, 1, dim);
            mat_mul(s.v, w.wv.offset(wv_offset), s.xb, kv_dim, 1, dim);
        }
    }
}

fn apply_rope(s: &RunState, w: &TransformerWeights, cfg: &Config, pos: i64, head_size: i64) {
    unsafe {
        for h in 0..cfg.n_heads {
            for i in 0..(head_size / 2) {
                let idx: i64 = h * head_size + i * 2;
                let idx_freq: i64 = pos * (head_size / 2) + i;
                let f_cr: f32 = w.freq_cis_real[idx_freq];
                let f_ci: f32 = w.freq_cis_imag[idx_freq];
                
                let v0: f32 = s.q[idx];
                let v1: f32 = s.q[idx + 1];
                s.q[idx] = v0 * f_cr - v1 * f_ci;
                s.q[idx + 1] = v0 * f_ci + v1 * f_cr;
            }
        }
        for h in 0..cfg.n_kv_heads {
            for i in 0..(head_size / 2) {
                let idx: i64 = h * head_size + i * 2;
                let idx_freq: i64 = pos * (head_size / 2) + i;
                let f_cr: f32 = w.freq_cis_real[idx_freq];
                let f_ci: f32 = w.freq_cis_imag[idx_freq];
                
                let v0: f32 = s.k[idx];
                let v1: f32 = s.k[idx + 1];
                s.k[idx] = v0 * f_cr - v1 * f_ci;
                s.k[idx + 1] = v0 * f_ci + v1 * f_cr;
            }
        }
    }
}

fn compute_attention(s: &RunState, cfg: &Config, l: i64, pos: i64, kv_dim: i64, head_size: i64, kv_mul: i64, sqrt_head_size: f32) {
    unsafe {
        // Cache KV
        let cache_offset: i64 = l * cfg.seq_len * kv_dim + pos * kv_dim;
        let k_cache_ptr = s.key_cache.offset(cache_offset);
        let v_cache_ptr = s.value_cache.offset(cache_offset);
        for i in 0..kv_dim {
            k_cache_ptr[i] = s.k[i];
            v_cache_ptr[i] = s.v[i];
        }

        // Multi-head attention
        for h in 0..cfg.n_heads {
            let att_offset: i64 = h * cfg.seq_len;
            let q_offset: i64 = h * head_size;
            
            for t in 0..(pos + 1) {
                let h_kv: i64 = h / kv_mul;
                let k_cache_t_offset: i64 = l * cfg.seq_len * kv_dim + t * kv_dim + h_kv * head_size;
                let k_ptr = s.key_cache.offset(k_cache_t_offset);
                
                let mut score: f32 = 0.0f32;
                for i in 0..head_size {
                    let q_val: f32 = s.q[q_offset + i];
                    let k_val: f32 = k_ptr[i];
                    score = score + q_val * k_val;
                }
                score = score / sqrt_head_size;
                s.att[att_offset + t] = score;
            }

            let att_head_ptr = s.att.offset(att_offset);
            softmax(att_head_ptr, pos + 1);

            let out_offset: i64 = h * head_size;
            for i in 0..head_size {
                let mut val: f32 = 0.0f32;
                for t in 0..(pos + 1) {
                    let h_kv: i64 = h / kv_mul;
                    let v_cache_t_offset: i64 = l * cfg.seq_len * kv_dim + t * kv_dim + h_kv * head_size;
                    let v_ptr = s.value_cache.offset(v_cache_t_offset);
                    
                    let att_w: f32 = att_head_ptr[t];
                    let v_val: f32 = v_ptr[i];
                    val = val + att_w * v_val;
                }
                s.xb[out_offset + i] = val;
            }
        }
    }
}

fn ffn_swiglu(s: &RunState, w: &TransformerWeights, dim: i64, hidden_dim: i64, l: i64) {
    unsafe {
        let w1_offset: i64 = l * hidden_dim * dim;
        let w2_offset: i64 = l * dim * hidden_dim;
        let w3_offset: i64 = l * hidden_dim * dim;
        
        if w.is_q8 == 1 {
            let w1_q8_off: i64 = l * hidden_dim * (dim / 32) * 34;
            let w3_q8_off: i64 = l * hidden_dim * (dim / 32) * 34;
            mat_mul_vec_q8(s.hb, w.w1_q8.offset(w1_q8_off), s.xb, hidden_dim, dim);
            mat_mul_vec_q8(s.hb2, w.w3_q8.offset(w3_q8_off), s.xb, hidden_dim, dim);
        } else {
            mat_mul(s.hb, w.w1.offset(w1_offset), s.xb, hidden_dim, 1, dim);
            mat_mul(s.hb2, w.w3.offset(w3_offset), s.xb, hidden_dim, 1, dim);
        }

        for i in 0..hidden_dim {
            let val: f32 = s.hb[i];
            let val2: f32 = s.hb2[i];
            let neg_val: f32 = 0.0f32 - val;
            let sigmoid: f32 = 1.0f32 / (1.0f32 + expf(neg_val));
            let silu: f32 = val * sigmoid;
            s.hb[i] = silu * val2; 
        }

        if w.is_q8 == 1 {
            let w2_q8_off: i64 = l * dim * (hidden_dim / 32) * 34;
            mat_mul_vec_q8(s.xb, w.w2_q8.offset(w2_q8_off), s.hb, dim, hidden_dim);
        } else {
            mat_mul(s.xb, w.w2.offset(w2_offset), s.hb, dim, 1, hidden_dim);
        }
    }
}

@fast_math
fn output_projection(s: &RunState, w: &TransformerWeights, dim: i64, l: i64) {
    unsafe {
        if w.is_q8 == 1 {
            let wo_q8_off: i64 = l * dim * (dim / 32) * 34;
            mat_mul_vec_q8(s.xb2, w.wo_q8.offset(wo_q8_off), s.xb, dim, dim);
        } else {
            mat_mul(s.xb2, w.wo.offset(l * dim * dim), s.xb, dim, 1, dim);
        }
    }
}

fn residual_add(x: Ptr<f32>, v: Ptr<f32>, dim: i64) {
    unsafe { for i in 0..dim { x[i] = x[i] + v[i]; } }
}

@fast_math
pub fn forward(cfg: &Config, w: &TransformerWeights, s: &RunState, token: i64, pos: i64) {
    unsafe {
        if s.x as i64 == 0 { return; }
        let dim: i64 = cfg.dim;
        let hidden_dim: i64 = cfg.hidden_dim;
        let head_size: i64 = dim / cfg.n_heads;
        let kv_dim: i64 = (dim * cfg.n_kv_heads) / cfg.n_heads;
        let kv_mul: i64 = cfg.n_heads / cfg.n_kv_heads; 
        let sqrt_head_size: f32 = sqrtf(head_size as f32);

        transformer_embedding(s, w, dim, token);
        
        for l in 0..cfg.n_layers {
            rmsnorm(s.xb, s.x, w.rms_att_weight.offset(l * dim), dim);
            project_qkv(s, w, dim, kv_dim, l);
            apply_rope(s, w, cfg, pos, head_size);
            compute_attention(s, cfg, l, pos, kv_dim, head_size, kv_mul, sqrt_head_size);
            output_projection(s, w, dim, l);
            residual_add(s.x, s.xb2, dim);
            rmsnorm(s.xb, s.x, w.rms_ffn_weight.offset(l * dim), dim);
            ffn_swiglu(s, w, dim, hidden_dim, l);
            residual_add(s.x, s.xb, dim);
        } 
        
        rmsnorm(s.x, s.x, w.rms_final_weight, dim);
        if w.is_q8 == 1 {
            mat_mul_vec_q8(s.logits, w.w_cls_q8, s.x, cfg.vocab_size, dim);
        } else {
            mat_mul(s.logits, w.w_cls, s.x, cfg.vocab_size, 1, dim);
        }
    }
}
