// =============================================================================
// Test: basalt.sampler — Token Sampling Tests
// =============================================================================
// Tests argmax, temperature-scaled sampling, and top-p (nucleus) sampling.
// Uses exit codes for assertion (0 = PASS, non-zero = specific failure).
// =============================================================================

package main

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn expf(x: f32) -> f32;

// ---- Utility ----

fn alloc_f32(count: i64) -> Ptr<f32> {
    let ptr: Ptr<u8> = malloc(count * 4);
    return ptr as Ptr<f32>;
}

fn approx_eq(a: f32, b: f32, tol: f32) -> bool {
    let diff = a - b;
    let abs_diff = if diff > 0.0f32 { diff } else { 0.0f32 - diff };
    return abs_diff < tol;
}

// ---- Sampler functions under test ----

fn sample_argmax(probabilities: Ptr<f32>, n: i64) -> i64
    requires n > 0
{
    let mut best_idx: i64 = 0;
    let mut best_val: f32 = probabilities[0];
    for i in 1..n {
        let v: f32 = probabilities[i];
        if v > best_val {
            best_val = v;
            best_idx = i;
        }
    }
    return best_idx;
}

fn sample_token(probabilities: Ptr<f32>, n: i64, coin: f32) -> i64
    requires n > 0
{
    let mut cdf: f32 = 0.0f32;
    for i in 0..n {
        cdf = cdf + probabilities[i];
        if coin < cdf {
            return i;
        }
    }
    return n - 1;
}

// Swap two f32 values at given pointer indices
fn swap_f32(arr: Ptr<f32>, a: i64, b: i64) {
    let tmp: f32 = arr[a];
    arr[b] = arr[a];
    arr[a] = tmp;
}

// Swap two i64 values at given pointer indices
fn swap_i64(arr: Ptr<i64>, a: i64, b: i64) {
    let tmp: i64 = arr[a];
    arr[b] = arr[a];
    arr[a] = tmp;
}

fn alloc_i64(count: i64) -> Ptr<i64> {
    let ptr: Ptr<u8> = malloc(count * 8);
    return ptr as Ptr<i64>;
}

fn sample_topp(probabilities: Ptr<f32>, n: i64, topp: f32, coin: f32) -> i64
    requires n > 0
{
    // Cutoff: skip tokens with tiny probability
    let cutoff: f32 = (1.0f32 - topp) / ((n - 1) as f32);

    // Build filtered list of (probability, index) pairs
    let prob_buf = alloc_f32(n);
    let idx_buf = alloc_i64(n);
    let mut n0: i64 = 0;
    for i in 0..n {
        let p: f32 = probabilities[i];
        if p >= cutoff {
            prob_buf[n0] = p;
            idx_buf[n0] = i;
            n0 = n0 + 1;
        }
    }

    // Simple insertion sort by probability descending
    for i in 1..n0 {
        let key_p: f32 = prob_buf[i];
        let key_i: i64 = idx_buf[i];
        let mut j: i64 = i - 1;
        // Move elements that are smaller than key
        for step in 0..i {
            if j >= 0 {
                let pj: f32 = prob_buf[j];
                if pj < key_p {
                    prob_buf[j + 1] = pj;
                    idx_buf[j + 1] = idx_buf[j];
                    j = j - 1;
                }
            }
        }
        prob_buf[j + 1] = key_p;
        idx_buf[j + 1] = key_i;
    }

    // Truncate to top-p cumulative mass
    let mut cumulative: f32 = 0.0f32;
    let mut last_idx: i64 = n0 - 1;
    for i in 0..n0 {
        cumulative = cumulative + prob_buf[i];
        if cumulative > topp {
            last_idx = i;
            // Break out by skipping rest
            for skip in 0..0 {}
        }
    }

    // Sample from the truncated distribution
    let r: f32 = coin * cumulative;
    let mut cdf: f32 = 0.0f32;
    for i in 0..last_idx + 1 {
        cdf = cdf + prob_buf[i];
        if r < cdf {
            return idx_buf[i];
        }
    }
    return idx_buf[last_idx];
}

// ---- Test Cases ----

fn test_argmax() -> i32 {
    let n: i64 = 5;
    let probs = alloc_f32(n);

    // Max at index 2
    probs[0] = 0.1f32;
    probs[1] = 0.2f32;
    probs[2] = 0.5f32;
    probs[3] = 0.15f32;
    probs[4] = 0.05f32;

    let idx: i64 = sample_argmax(probs, n);
    if idx != 2 { return 401; }

    // Max at index 0
    probs[0] = 0.9f32;
    probs[1] = 0.025f32;
    probs[2] = 0.025f32;
    probs[3] = 0.025f32;
    probs[4] = 0.025f32;

    let idx2: i64 = sample_argmax(probs, n);
    if idx2 != 0 { return 402; }

    // Max at last index
    probs[0] = 0.01f32;
    probs[1] = 0.01f32;
    probs[2] = 0.01f32;
    probs[3] = 0.01f32;
    probs[4] = 0.96f32;

    let idx3: i64 = sample_argmax(probs, n);
    if idx3 != 4 { return 403; }

    // Single element
    let one = alloc_f32(1);
    one[0] = 42.0f32;
    let idx4: i64 = sample_argmax(one, 1);
    if idx4 != 0 { return 404; }

    return 0;
}

fn test_sample_token() -> i32 {
    let n: i64 = 4;
    let probs = alloc_f32(n);

    // Probabilities that sum to 1.0
    probs[0] = 0.1f32;
    probs[1] = 0.2f32;
    probs[2] = 0.3f32;
    probs[3] = 0.4f32;

    // coin = 0.05 → should select index 0 (CDF: 0.1)
    let r1: i64 = sample_token(probs, n, 0.05f32);
    if r1 != 0 { return 501; }

    // coin = 0.15 → should select index 1 (CDF: 0.1, 0.3)
    let r2: i64 = sample_token(probs, n, 0.15f32);
    if r2 != 1 { return 502; }

    // coin = 0.35 → should select index 2 (CDF: 0.1, 0.3, 0.6)
    let r3: i64 = sample_token(probs, n, 0.35f32);
    if r3 != 2 { return 503; }

    // coin = 0.95 → should select index 3 (CDF: 0.1, 0.3, 0.6, 1.0)
    let r4: i64 = sample_token(probs, n, 0.95f32);
    if r4 != 3 { return 504; }

    // coin = 0.999 → should select last index (fallback)
    let r5: i64 = sample_token(probs, n, 0.999f32);
    if r5 != 3 { return 505; }

    return 0;
}

fn test_topp() -> i32 {
    let n: i64 = 5;
    let probs = alloc_f32(n);

    // Distribution: one dominant token
    probs[0] = 0.7f32;
    probs[1] = 0.1f32;
    probs[2] = 0.1f32;
    probs[3] = 0.05f32;
    probs[4] = 0.05f32;

    // topp = 0.9, coin = 0.0 → should pick the highest-prob token (index 0)
    let r1: i64 = sample_topp(probs, n, 0.9f32, 0.0f32);
    if r1 != 0 { return 601; }

    // topp = 1.0 (no truncation), coin = 0.0 → should pick first token
    let r2: i64 = sample_topp(probs, n, 1.0f32, 0.0f32);
    if r2 != 0 { return 602; }

    return 0;
}

fn main() -> i32 {
    let r1: i32 = test_argmax();
    if r1 != 0 {
        println(f"FAIL: test_argmax (code {r1})");
        return r1;
    }
    println("  ✓ argmax");

    let r2: i32 = test_sample_token();
    if r2 != 0 {
        println(f"FAIL: test_sample_token (code {r2})");
        return r2;
    }
    println("  ✓ sample_token");

    let r3: i32 = test_topp();
    if r3 != 0 {
        println(f"FAIL: test_topp (code {r3})");
        return r3;
    }
    println("  ✓ sample_topp");

    println("basalt sampler: PASS");
    return 0;
}
