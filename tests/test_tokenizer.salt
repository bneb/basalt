// =============================================================================
// Test: basalt.tokenizer — BPE Tokenizer Tests (TDD)
// =============================================================================
// Tests token decoding and BPE encoding with a hand-built vocabulary.
// Uses exit codes for assertion (0 = PASS, non-zero = specific failure).
//
// All test functions use single-exit cleanup: every code path frees
// its allocations before returning, satisfying Z3's ownership verification.
//
// NOTE: Test data construction uses direct byte-level array indexing
// (not .offset() + cast) to avoid a Z3 provenance tracking issue where
// multiple functions using buf.offset() triggers a false-positive leak.
// =============================================================================

package main

import std.io.println
import std.core.ptr.Ptr

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);

// ---- Utility ----

fn alloc_u8(count: i64) -> Ptr<u8> {
    return malloc(count);
}

fn alloc_i64(count: i64) -> Ptr<i64> {
    let ptr: Ptr<u8> = malloc(count * 8);
    return ptr as Ptr<i64>;
}

fn str_eq(a: Ptr<u8>, a_len: i64, b: Ptr<u8>, b_len: i64) -> bool {
    if a_len != b_len { return false; }
    for i in 0..a_len {
        if a[i] != b[i] { return false; }
    }
    return true;
}

// ---- Byte-level write helpers ----
// These avoid buf.offset() + cast to prevent Z3 provenance false positives.

fn put_i32(buf: Ptr<u8>, offset: i64, val: i32) -> i64 {
    buf[offset]     = (val & 255) as u8;
    buf[offset + 1] = ((val >> 8) & 255) as u8;
    buf[offset + 2] = ((val >> 16) & 255) as u8;
    buf[offset + 3] = ((val >> 24) & 255) as u8;
    return offset + 4;
}

// Write raw f32 bytes (little-endian IEEE 754)
fn put_f32_bytes(buf: Ptr<u8>, offset: i64, b0: u8, b1: u8, b2: u8, b3: u8) -> i64 {
    buf[offset]     = b0;
    buf[offset + 1] = b1;
    buf[offset + 2] = b2;
    buf[offset + 3] = b3;
    return offset + 4;
}

// Known f32 byte patterns (little-endian IEEE 754):
//   0.0  = 0x00000000 → 0x00, 0x00, 0x00, 0x00
//   5.0  = 0x40A00000 → 0x00, 0x00, 0xA0, 0x40
//  10.0  = 0x41200000 → 0x00, 0x00, 0x20, 0x41
//  20.0  = 0x41A00000 → 0x00, 0x00, 0xA0, 0x41

// ---- Tokenizer Structs (must match tokenizer.salt) ----

struct TokenizerEntry {
    text: Ptr<u8>,
    len: i32,
    score: f32,
}

struct SpecialToken {
    text: Ptr<u8>,
    len: i64,
    token_id: i64,
}

struct Tokenizer {
    vocab: Ptr<TokenizerEntry>,
    vocab_size: i64,
    max_token_length: i32,
    text_arena: Ptr<u8>,
    special_tokens: Ptr<SpecialToken>,
    n_special: i64,
    special_capacity: i64,
}

// ---- Tokenizer Implementation Under Test ----

fn load_tokenizer(data: Ptr<u8>, vocab_size: i64) -> Tokenizer {
    // Read max_token_length as i32 (little-endian) from first 4 bytes
    let b0: i32 = data[0] as i32;
    let b1: i32 = data[1] as i32;
    let b2: i32 = data[2] as i32;
    let b3: i32 = data[3] as i32;
    let max_len: i32 = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
    let mut offset: i64 = 4;
    
    let entry_size: i64 = 24;
    let vocab_buf = malloc(vocab_size * entry_size);
    let vocab = vocab_buf as Ptr<TokenizerEntry>;
    
    // Single contiguous arena for all token text
    let arena_size: i64 = vocab_size * (max_len as i64 + 1);
    let text_arena = malloc(arena_size);
    let mut arena_offset: i64 = 0;
    
    for i in 0..vocab_size {
        // Read score as f32 — skip 4 bytes (we don't need the score for
        // test data construction validation, but load_tokenizer must
        // advance the offset). Read via the data pointer with cast.
        // Use a single .offset() for each read to avoid multiple provenance.
        let score_ptr = data.offset(offset) as Ptr<f32>;
        let score: f32 = score_ptr[0];
        offset = offset + 4;
        
        // Read len as i32 via byte-level
        let lb0: i32 = data[offset] as i32;
        let lb1: i32 = data[offset + 1] as i32;
        let lb2: i32 = data[offset + 2] as i32;
        let lb3: i32 = data[offset + 3] as i32;
        let len: i32 = lb0 | (lb1 << 8) | (lb2 << 16) | (lb3 << 24);
        offset = offset + 4;
        
        // Copy text bytes into arena + null terminator
        // Use direct indexing into text_arena instead of .offset()
        for j in 0..(len as i64) {
            text_arena[arena_offset + j] = data[offset + j];
        }
        text_arena[arena_offset + len as i64] = 0;
        
        // Build entry with pointer into arena using .offset() — only one call
        let text_ptr = text_arena.offset(arena_offset);
        arena_offset = arena_offset + len as i64 + 1;
        offset = offset + len as i64;
        
        vocab[i] = TokenizerEntry { text: text_ptr, len: len, score: score };
    }
    
    // Allocate special token registry (capacity 16)
    let special_cap: i64 = 16;
    let special_buf = malloc(special_cap * 24); // sizeof(SpecialToken) = 8+8+8 = 24
    let special_tokens = special_buf as Ptr<SpecialToken>;
    
    return Tokenizer {
        vocab: vocab,
        vocab_size: vocab_size,
        max_token_length: max_len,
        text_arena: text_arena,
        special_tokens: special_tokens,
        n_special: 0,
        special_capacity: special_cap,
    };
}

fn free_tokenizer(tok: Tokenizer) {
    free(tok.text_arena);
    free(tok.vocab as Ptr<u8>);
    free(tok.special_tokens as Ptr<u8>);
}

// Register a special token for pre-scan matching during bpe_encode.
fn register_special_token(tok: Ptr<Tokenizer>, text: Ptr<u8>, len: i64, token_id: i64) {
    let t = tok[0];
    if t.n_special >= t.special_capacity {
        return;
    }
    t.special_tokens[t.n_special] = SpecialToken { text: text, len: len, token_id: token_id };
    tok[0] = Tokenizer {
        vocab: t.vocab,
        vocab_size: t.vocab_size,
        max_token_length: t.max_token_length,
        text_arena: t.text_arena,
        special_tokens: t.special_tokens,
        n_special: t.n_special + 1,
        special_capacity: t.special_capacity,
    };
}

fn decode_token(tok: Tokenizer, token_id: i64) -> Ptr<u8> {
    if token_id < 0 { return 0 as Ptr<u8>; }
    if token_id >= tok.vocab_size { return 0 as Ptr<u8>; }
    return tok.vocab[token_id].text;
}

fn decode_token_len(tok: Tokenizer, token_id: i64) -> i32 {
    if token_id < 0 { return 0; }
    if token_id >= tok.vocab_size { return 0; }
    return tok.vocab[token_id].len;
}

fn find_token(tok: Tokenizer, text: Ptr<u8>, text_len: i64) -> i64 {
    for i in 0..tok.vocab_size {
        let entry = tok.vocab[i];
        if str_eq(entry.text, entry.len as i64, text, text_len) {
            return i;
        }
    }
    return -1;
}

// Check if text at position pos matches a special token.
// Returns the index into special_tokens array, or -1 if no match.
// When multiple specials match, returns the longest match.
fn match_special(tok: Tokenizer, text: Ptr<u8>, pos: i64, text_len: i64) -> i64 {
    let mut best: i64 = -1;
    let mut best_len: i64 = 0;
    let remaining = text_len - pos;
    for i in 0..tok.n_special {
        let sp = tok.special_tokens[i];
        if sp.len <= remaining {
            if sp.len > best_len {
                let mut match_ok: i32 = 1;
                for j in 0..sp.len {
                    if text[pos + j] != sp.text[j] {
                        match_ok = 0;
                    }
                }
                if match_ok != 0 {
                    best = i;
                    best_len = sp.len;
                }
            }
        }
    }
    return best;
}

// BPE-encode a non-special text segment (byte-init + merge loop).
// Appends tokens to out_tokens starting at offset, returns new offset.
fn bpe_encode_segment(tok: Tokenizer, text: Ptr<u8>, seg_start: i64, seg_len: i64, out_tokens: Ptr<i64>, offset: i64) -> i64 {
    if seg_len <= 0 { return offset; }
    
    let mut n: i64 = offset;
    
    // Step 1: Initialize — each byte becomes a single-byte token
    for i in 0..seg_len {
        let byte_buf = malloc(1);
        byte_buf[0] = text[seg_start + i];
        let tid = find_token(tok, byte_buf, 1);
        if tid >= 0 {
            out_tokens[n] = tid;
            n = n + 1;
        }
        free(byte_buf);
    }
    
    // Step 2: BPE merge — repeatedly merge best adjacent pair
    // Only merge tokens within this segment (from offset to n)
    let seg_token_start = offset;
    let merge_buf = malloc(tok.max_token_length as i64 + 1);
    
    let mut changed: i32 = 1;
    for iter in 0..1000 {
        if changed == 0 {
            // done
        }
        if changed != 0 {
            changed = 0;
            let seg_count = n - seg_token_start;
            let mut best_score: f32 = -1000000.0f32;
            let mut best_idx: i64 = -1;
            let mut best_tid: i64 = -1;
            
            for i in 0..(seg_count - 1) {
                let abs_i = seg_token_start + i;
                let t1 = out_tokens[abs_i];
                let t2 = out_tokens[abs_i + 1];
                let len1 = tok.vocab[t1].len as i64;
                let len2 = tok.vocab[t2].len as i64;
                let merged_len = len1 + len2;
                
                let t1_text = tok.vocab[t1].text;
                for j in 0..len1 {
                    merge_buf[j] = t1_text[j];
                }
                let t2_text = tok.vocab[t2].text;
                for j in 0..len2 {
                    merge_buf[len1 + j] = t2_text[j];
                }
                
                let mid = find_token(tok, merge_buf, merged_len);
                if mid >= 0 {
                    let score = tok.vocab[mid].score;
                    if score > best_score {
                        best_score = score;
                        best_idx = abs_i;
                        best_tid = mid;
                    }
                }
            }
            
            if best_idx >= 0 {
                out_tokens[best_idx] = best_tid;
                let shift_from = best_idx + 2;
                for j in shift_from..n {
                    out_tokens[j - 1] = out_tokens[j];
                }
                n = n - 1;
                changed = 1;
            }
        }
    }
    
    free(merge_buf);
    return n;
}

fn find_next_special_or_end(tok: Tokenizer, text: Ptr<u8>, start: i64, text_len: i64) -> i64 {
    let mut seg_end = start + 1;
    while seg_end < text_len {
        let next_sp = match_special(tok, text, seg_end, text_len);
        if next_sp >= 0 {
            return seg_end;
        }
        seg_end = seg_end + 1;
    }
    return text_len;
}

fn bpe_encode(tok: Tokenizer, text: Ptr<u8>, text_len: i64, out_tokens: Ptr<i64>) -> i64 {
    let mut n_tokens: i64 = 0;
    let mut pos: i64 = 0;
    
    while pos < text_len {
        let sp_idx = match_special(tok, text, pos, text_len);
        if sp_idx >= 0 {
            // Emit special token directly
            out_tokens[n_tokens] = tok.special_tokens[sp_idx].token_id;
            n_tokens = n_tokens + 1;
            pos = pos + tok.special_tokens[sp_idx].len;
        } else {
            // Find the end of this non-special segment
            let seg_end = find_next_special_or_end(tok, text, pos, text_len);
            
            // BPE-encode the normal segment
            n_tokens = bpe_encode_segment(tok, text, pos, seg_end - pos, out_tokens, n_tokens);
            pos = seg_end;
        }
    }
    
    return n_tokens;
}

// ---- Build Test Vocabulary ----
// Vocab:
//   0: "a"   score=0.0
//   1: "b"   score=0.0
//   2: "c"   score=0.0
//   3: "d"   score=0.0
//   4: "ab"  score=10.0
//   5: "cd"  score=5.0
//   6: "abc" score=20.0
//
// Binary format: [max_token_length: i32] then [score: f32][len: i32][bytes...]
// All integers are little-endian. f32 scores use raw IEEE 754 byte patterns.

fn build_test_vocab() -> Ptr<u8> {
    let buf = alloc_u8(4096);
    let mut off: i64 = 0;
    
    // Header: max_token_length = 3
    off = put_i32(buf, off, 3);
    
    // Entry 0: "a", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0); // 0.0f32
    off = put_i32(buf, off, 1);
    buf[off] = 97; off = off + 1; // 'a'
    
    // Entry 1: "b", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 98; off = off + 1; // 'b'
    
    // Entry 2: "c", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 99; off = off + 1; // 'c'
    
    // Entry 3: "d", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 100; off = off + 1; // 'd'
    
    // Entry 4: "ab", score=10.0 (0x41200000)
    off = put_f32_bytes(buf, off, 0, 0, 32, 65); // 0x00, 0x00, 0x20, 0x41
    off = put_i32(buf, off, 2);
    buf[off] = 97; off = off + 1;  // 'a'
    buf[off] = 98; off = off + 1;  // 'b'
    
    // Entry 5: "cd", score=5.0 (0x40A00000)
    off = put_f32_bytes(buf, off, 0, 0, 160, 64); // 0x00, 0x00, 0xA0, 0x40
    off = put_i32(buf, off, 2);
    buf[off] = 99; off = off + 1;  // 'c'
    buf[off] = 100; off = off + 1; // 'd'
    
    // Entry 6: "abc", score=20.0 (0x41A00000)
    off = put_f32_bytes(buf, off, 0, 0, 160, 65); // 0x00, 0x00, 0xA0, 0x41
    off = put_i32(buf, off, 3);
    buf[off] = 97; off = off + 1;  // 'a'
    buf[off] = 98; off = off + 1;  // 'b'
    buf[off] = 99; off = off + 1;  // 'c'
    
    return buf;
}

// ---- Build Special Token Vocab ----
// Extended vocab that includes special tokens for pre-scan testing.
// Vocab:
//   0: "\n"     score=0.0   (newline, single byte 0x0A)
//   1: "<|s|>"  score=0.0   (5 bytes: 0x3C 0x7C 0x73 0x7C 0x3E)
//   2: "<|e|>"  score=0.0   (5 bytes: 0x3C 0x7C 0x65 0x7C 0x3E)
//   3: "a"      score=0.0   (single byte 0x61)
//   4: "b"      score=0.0   (single byte 0x62)
//   5: "<"      score=0.0   (single byte 0x3C — needed for byte fallback)
//   6: "|"      score=0.0   (single byte 0x7C)
//   7: "s"      score=0.0   (single byte 0x73)
//   8: "e"      score=0.0   (single byte 0x65)
//   9: ">"      score=0.0   (single byte 0x3E)
//  10: "ab"     score=10.0  (merged pair)
//
// max_token_length = 5

fn build_special_vocab() -> Ptr<u8> {
    let buf = alloc_u8(4096);
    let mut off: i64 = 0;
    
    // Header: max_token_length = 5
    off = put_i32(buf, off, 5);
    
    // Entry 0: "\n" (0x0A), score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 10; off = off + 1; // '\n'
    
    // Entry 1: "<|s|>" (5 bytes), score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 5);
    buf[off] = 60; off = off + 1;  // '<'
    buf[off] = 124; off = off + 1; // '|'
    buf[off] = 115; off = off + 1; // 's'
    buf[off] = 124; off = off + 1; // '|'
    buf[off] = 62; off = off + 1;  // '>'
    
    // Entry 2: "<|e|>" (5 bytes), score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 5);
    buf[off] = 60; off = off + 1;  // '<'
    buf[off] = 124; off = off + 1; // '|'
    buf[off] = 101; off = off + 1; // 'e'
    buf[off] = 124; off = off + 1; // '|'
    buf[off] = 62; off = off + 1;  // '>'
    
    // Entry 3: "a", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 97; off = off + 1; // 'a'
    
    // Entry 4: "b", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 98; off = off + 1; // 'b'
    
    // Entry 5: "<", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 60; off = off + 1; // '<'
    
    // Entry 6: "|", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 124; off = off + 1; // '|'
    
    // Entry 7: "s", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 115; off = off + 1; // 's'
    
    // Entry 8: "e", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 101; off = off + 1; // 'e'
    
    // Entry 9: ">", score=0.0
    off = put_f32_bytes(buf, off, 0, 0, 0, 0);
    off = put_i32(buf, off, 1);
    buf[off] = 62; off = off + 1; // '>'
    
    // Entry 10: "ab", score=10.0 (0x41200000)
    off = put_f32_bytes(buf, off, 0, 0, 32, 65);
    off = put_i32(buf, off, 2);
    buf[off] = 97; off = off + 1;  // 'a'
    buf[off] = 98; off = off + 1;  // 'b'
    
    return buf;
}

// ---- Test Cases ----
// Single-exit cleanup: result variable accumulates errors,
// single exit point frees all allocations.

fn test_load_tokenizer() -> i32 {
    let buf = build_test_vocab();
    let tok = load_tokenizer(buf, 7);
    let mut result: i32 = 0;
    
    if result == 0 { if tok.max_token_length != 3 { result = 101; } }
    if result == 0 { if tok.vocab_size != 7 { result = 102; } }
    
    if result == 0 {
        let e0 = tok.vocab[0];
        if e0.len != 1 { result = 103; }
        if result == 0 { if e0.text[0] != 97 { result = 104; } }
    }
    
    if result == 0 {
        let e4 = tok.vocab[4];
        if e4.len != 2 { result = 105; }
        if result == 0 { if e4.text[0] != 97 { result = 106; } }
        if result == 0 { if e4.text[1] != 98 { result = 107; } }
    }
    
    free_tokenizer(tok);
    free(buf);
    return result;
}

fn test_decode_token() -> i32 {
    let buf = build_test_vocab();
    let tok = load_tokenizer(buf, 7);
    let mut result: i32 = 0;
    
    if result == 0 { let t0 = decode_token(tok, 0); if t0[0] != 97 { result = 201; } }
    if result == 0 { let t4 = decode_token(tok, 4); if t4[0] != 97 { result = 202; } }
    if result == 0 { let t4b = decode_token(tok, 4); if t4b[1] != 98 { result = 203; } }
    if result == 0 { let t6 = decode_token(tok, 6); if t6[0] != 97 { result = 204; } }
    if result == 0 { let t6b = decode_token(tok, 6); if t6b[1] != 98 { result = 205; } }
    if result == 0 { let t6c = decode_token(tok, 6); if t6c[2] != 99 { result = 206; } }
    if result == 0 {
        let bad = decode_token(tok, 100);
        let bad_addr = bad as i64;
        if bad_addr != 0 { result = 207; }
    }
    
    free_tokenizer(tok);
    free(buf);
    return result;
}

fn test_find_token() -> i32 {
    let buf = build_test_vocab();
    let tok = load_tokenizer(buf, 7);
    let mut result: i32 = 0;
    
    let a_buf = alloc_u8(1);
    a_buf[0] = 97;
    let r1 = find_token(tok, a_buf, 1);
    if r1 != 0 { result = 301; }
    free(a_buf);
    
    if result == 0 {
        let ab_buf = alloc_u8(2);
        ab_buf[0] = 97;
        ab_buf[1] = 98;
        let r2 = find_token(tok, ab_buf, 2);
        if r2 != 4 { result = 302; }
        free(ab_buf);
    }
    
    if result == 0 {
        let xyz_buf = alloc_u8(3);
        xyz_buf[0] = 120;
        xyz_buf[1] = 121;
        xyz_buf[2] = 122;
        let r3 = find_token(tok, xyz_buf, 3);
        if r3 != -1 { result = 303; }
        free(xyz_buf);
    }
    
    free_tokenizer(tok);
    free(buf);
    return result;
}

fn test_bpe_encode() -> i32 {
    let buf = build_test_vocab();
    let tok = load_tokenizer(buf, 7);
    let mut result: i32 = 0;
    
    // Encode "abcd" -> [abc=6, d=3]
    let text = alloc_u8(4);
    text[0] = 97;  // 'a'
    text[1] = 98;  // 'b'
    text[2] = 99;  // 'c'
    text[3] = 100; // 'd'
    let out = alloc_i64(16);
    let n = bpe_encode(tok, text, 4, out);
    if n != 2 { result = 401; }
    if result == 0 { if out[0] != 6 { result = 402; } }
    if result == 0 { if out[1] != 3 { result = 403; } }
    free(text);
    free(out as Ptr<u8>);
    
    // Encode "ab" -> [ab=4]
    if result == 0 {
        let text2 = alloc_u8(2);
        text2[0] = 97;
        text2[1] = 98;
        let out2 = alloc_i64(16);
        let n2 = bpe_encode(tok, text2, 2, out2);
        if n2 != 1 { result = 404; }
        if result == 0 { if out2[0] != 4 { result = 405; } }
        free(text2);
        free(out2 as Ptr<u8>);
    }
    
    // Encode "a" -> [a=0]
    if result == 0 {
        let text3 = alloc_u8(1);
        text3[0] = 97;
        let out3 = alloc_i64(16);
        let n3 = bpe_encode(tok, text3, 1, out3);
        if n3 != 1 { result = 406; }
        if result == 0 { if out3[0] != 0 { result = 407; } }
        free(text3);
        free(out3 as Ptr<u8>);
    }
    
    // Encode "cd" -> [cd=5]
    if result == 0 {
        let text4 = alloc_u8(2);
        text4[0] = 99;
        text4[1] = 100;
        let out4 = alloc_i64(16);
        let n4 = bpe_encode(tok, text4, 2, out4);
        if n4 != 1 { result = 408; }
        if result == 0 { if out4[0] != 5 { result = 409; } }
        free(text4);
        free(out4 as Ptr<u8>);
    }
    
    free_tokenizer(tok);
    free(buf);
    return result;
}

// ---- Special Token Tests ----
// Tests that bpe_encode with registered special tokens emits them as
// single token IDs instead of fragmenting into byte tokens.
//
// Test cases:
//   501: "a<|s|>b" → [a=3, <|s|>=1, b=4]  (3 tokens, not 7)
//   504: "<|s|>"   → [<|s|>=1]             (1 token, not 5)
//   506: "<|s|>ab<|e|>" → [<|s|>=1, ab=10, <|e|>=2] (3 tokens)
//   510: "\n"      → [\n=0]                (1 token, registered special)
//   512: "<|s|>\n<|e|>" → [<|s|>=1, \n=0, <|e|>=2] (3 tokens)

fn test_special_tokens() -> i32 {
    let buf = build_special_vocab();
    let tok = load_tokenizer(buf, 11); // 11 vocab entries
    let mut result: i32 = 0;
    
    // Register special tokens: <|s|> -> 1, <|e|> -> 2, \n -> 0
    let sp1 = alloc_u8(5);
    sp1[0] = 60; sp1[1] = 124; sp1[2] = 115; sp1[3] = 124; sp1[4] = 62; // "<|s|>"
    let sp2 = alloc_u8(5);
    sp2[0] = 60; sp2[1] = 124; sp2[2] = 101; sp2[3] = 124; sp2[4] = 62; // "<|e|>"
    let sp3 = alloc_u8(1);
    sp3[0] = 10; // "\n"
    
    // Store tok on heap so we can pass Ptr<Tokenizer> to register_special_token
    let tok_ptr = malloc(64) as Ptr<Tokenizer>;
    tok_ptr[0] = tok;
    register_special_token(tok_ptr, sp1, 5, 1);
    register_special_token(tok_ptr, sp2, 5, 2);
    register_special_token(tok_ptr, sp3, 1, 0);
    let tok2 = tok_ptr[0];
    
    // Test 1: "a<|s|>b" → [a=3, <|s|>=1, b=4]
    if result == 0 {
        let text = alloc_u8(7);
        text[0] = 97;  // 'a'
        text[1] = 60;  // '<'
        text[2] = 124; // '|'
        text[3] = 115; // 's'
        text[4] = 124; // '|'
        text[5] = 62;  // '>'
        text[6] = 98;  // 'b'
        let out = alloc_i64(16);
        let n = bpe_encode(tok2, text, 7, out);
        if n != 3 { result = 501; }
        if result == 0 { if out[0] != 3 { result = 502; } }  // 'a' = token 3
        if result == 0 { if out[1] != 1 { result = 503; } }  // '<|s|>' = token 1
        if result == 0 { if out[2] != 4 { result = 504; } }  // 'b' = token 4
        free(text);
        free(out as Ptr<u8>);
    }
    
    // Test 2: "<|s|>" alone → [<|s|>=1]
    if result == 0 {
        let text = alloc_u8(5);
        text[0] = 60; text[1] = 124; text[2] = 115; text[3] = 124; text[4] = 62;
        let out = alloc_i64(16);
        let n = bpe_encode(tok2, text, 5, out);
        if n != 1 { result = 505; }
        if result == 0 { if out[0] != 1 { result = 506; } }
        free(text);
        free(out as Ptr<u8>);
    }
    
    // Test 3: "<|s|>ab<|e|>" → [<|s|>=1, ab=10, <|e|>=2]
    if result == 0 {
        let text = alloc_u8(12);
        text[0] = 60; text[1] = 124; text[2] = 115; text[3] = 124; text[4] = 62;   // <|s|>
        text[5] = 97; text[6] = 98;                                                  // ab
        text[7] = 60; text[8] = 124; text[9] = 101; text[10] = 124; text[11] = 62;  // <|e|>
        let out = alloc_i64(16);
        let n = bpe_encode(tok2, text, 12, out);
        if n != 3 { result = 507; }
        if result == 0 { if out[0] != 1 { result = 508; } }   // <|s|>
        if result == 0 { if out[1] != 10 { result = 509; } }  // ab = token 10
        if result == 0 { if out[2] != 2 { result = 510; } }   // <|e|>
        free(text);
        free(out as Ptr<u8>);
    }
    
    // Test 4: "\n" → [\n=0]
    if result == 0 {
        let text = alloc_u8(1);
        text[0] = 10; // '\n'
        let out = alloc_i64(16);
        let n = bpe_encode(tok2, text, 1, out);
        if n != 1 { result = 511; }
        if result == 0 { if out[0] != 0 { result = 512; } }
        free(text);
        free(out as Ptr<u8>);
    }
    
    // Test 5: "<|s|>\n<|e|>" → [<|s|>=1, \n=0, <|e|>=2]
    if result == 0 {
        let text = alloc_u8(11);
        text[0] = 60; text[1] = 124; text[2] = 115; text[3] = 124; text[4] = 62;   // <|s|>
        text[5] = 10;                                                                // \n
        text[6] = 60; text[7] = 124; text[8] = 101; text[9] = 124; text[10] = 62;   // <|e|>
        let out = alloc_i64(16);
        let n = bpe_encode(tok2, text, 11, out);
        if n != 3 { result = 513; }
        if result == 0 { if out[0] != 1 { result = 514; } }   // <|s|>
        if result == 0 { if out[1] != 0 { result = 515; } }   // \n
        if result == 0 { if out[2] != 2 { result = 516; } }   // <|e|>
        free(text);
        free(out as Ptr<u8>);
    }
    
    // Cleanup
    free(sp1);
    free(sp2);
    free(sp3);
    free(tok_ptr as Ptr<u8>);
    free_tokenizer(tok2);
    free(buf);
    return result;
}

fn main() -> i32 {
    let r1 = test_load_tokenizer();
    if r1 != 0 {
        println(f"FAIL: test_load_tokenizer (code {r1})");
        return r1;
    }
    println("  ✓ load_tokenizer");
    
    let r2 = test_decode_token();
    if r2 != 0 {
        println(f"FAIL: test_decode_token (code {r2})");
        return r2;
    }
    println("  ✓ decode_token");
    
    let r3 = test_find_token();
    if r3 != 0 {
        println(f"FAIL: test_find_token (code {r3})");
        return r3;
    }
    println("  ✓ find_token");
    
    let r4 = test_bpe_encode();
    if r4 != 0 {
        println(f"FAIL: test_bpe_encode (code {r4})");
        return r4;
    }
    println("  ✓ bpe_encode");
    
    let r5 = test_special_tokens();
    if r5 != 0 {
        println(f"FAIL: test_special_tokens (code {r5})");
        return r5;
    }
    println("  ✓ special_tokens");
    
    println("basalt tokenizer: PASS");
    return 0;
}
