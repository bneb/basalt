// =============================================================================
// Test: Basalt Brutalist WASM API (6 exports)
// =============================================================================
//
// TDD RED→GREEN for the brutalist API:
//   basalt_alloc → basalt_init → basalt_ingest_prompt → basalt_generate_next
//   basalt_get_config → basalt_free
//
// Tests: init, bulk prefill, generate, unified config getter, free, re-init.
// =============================================================================

package main

import std.io.println
import std.core.ptr.Ptr

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: Ptr<u8>);
extern fn cosf(x: f32) -> f32;
extern fn sinf(x: f32) -> f32;
extern fn powf(base: f32, exp: f32) -> f32;
extern fn write(fd: i32, buf: Ptr<u8>, count: i64) -> i64;
extern fn salt_clock_now() -> i64;
extern fn salt_get_argc() -> i32;
extern fn salt_get_argv(idx: i32) -> Ptr<u8>;
extern fn salt_get_prompt_count() -> i64;
extern fn salt_get_prompt_token(idx: i64) -> i64;
extern fn open(path: Ptr<u8>, flags: i32) -> i32;
extern fn mmap(addr: Ptr<u8>, len: u64, prot: i32, flags: i32, fd: i32, offset: i64) -> Ptr<u8>;
extern fn close(fd: i32) -> i32;

// Build a tiny model buffer in llama2.c binary format
// dim=4, hidden_dim=8, n_layers=1, n_heads=1, n_kv_heads=1, vocab_size=8, seq_len=8
fn build_mock_model() -> Ptr<u8> {
    let dim: i64 = 4;
    let hidden_dim: i64 = 8;
    let n_layers: i64 = 1;
    let n_heads: i64 = 1;
    let n_kv_heads: i64 = 1;
    let vocab_size: i64 = 8;
    let seq_len: i64 = 8;

    let n_weights: i64 = 0
        + vocab_size * dim
        + n_layers * dim
        + n_layers * dim * dim
        + n_layers * dim * dim
        + n_layers * dim * dim
        + n_layers * dim * dim
        + n_layers * dim
        + n_layers * dim * hidden_dim
        + n_layers * hidden_dim * dim
        + n_layers * dim * hidden_dim
        + dim;

    let header_bytes: i64 = 7 * 4;
    let weight_bytes: i64 = n_weights * 4;
    let total_bytes: i64 = header_bytes + weight_bytes;

    let buf = malloc(total_bytes);

    let header = buf as Ptr<i32>;
    header[0] = dim as i32;
    header[1] = hidden_dim as i32;
    header[2] = n_layers as i32;
    header[3] = n_heads as i32;
    header[4] = n_kv_heads as i32;
    header[5] = vocab_size as i32;
    header[6] = seq_len as i32;

    let weights = buf.offset(header_bytes) as Ptr<f32>;
    for i in 0..n_weights {
        weights[i] = 0.01f32;
    }

    return buf;
}

fn main() -> i32 {
    let mut failed: i32 = 0;

    // ── Test 1: Init ────────────────────────────────────────────────────
    println("TEST 1: basalt_engine_init...");
    let model = build_mock_model();
    let es = basalt_engine_init(model, 0);
    if (es as i64) != 0 {
        println("  PASS: init returned non-null");
    } else {
        println("  FAIL: init returned null");
        failed = 1;
    }

    // ── Test 2: basalt_get_config (unified getter) ──────────────────────
    println("TEST 2: basalt_engine_get_config (all 7 param IDs)...");

    // param_id: 0=dim, 1=hidden_dim, 2=n_layers, 3=n_heads,
    //           4=n_kv_heads, 5=vocab_size, 6=seq_len
    let expected_dim: i64 = 4;
    let expected_hidden: i64 = 8;
    let expected_layers: i64 = 1;
    let expected_heads: i64 = 1;
    let expected_kv: i64 = 1;
    let expected_vocab: i64 = 8;
    let expected_seq: i64 = 8;

    let v0 = basalt_engine_get_config(es, 0);
    if v0 == expected_dim { println("  PASS: config[0] dim = {}", v0); }
    else { println("  FAIL: config[0] dim = {} (expected {})", v0, expected_dim); failed = 1; }

    let v1 = basalt_engine_get_config(es, 1);
    if v1 == expected_hidden { println("  PASS: config[1] hidden_dim = {}", v1); }
    else { println("  FAIL: config[1] hidden_dim = {} (expected {})", v1, expected_hidden); failed = 1; }

    let v2 = basalt_engine_get_config(es, 2);
    if v2 == expected_layers { println("  PASS: config[2] n_layers = {}", v2); }
    else { println("  FAIL: config[2] n_layers = {} (expected {})", v2, expected_layers); failed = 1; }

    let v3 = basalt_engine_get_config(es, 3);
    if v3 == expected_heads { println("  PASS: config[3] n_heads = {}", v3); }
    else { println("  FAIL: config[3] n_heads = {} (expected {})", v3, expected_heads); failed = 1; }

    let v4 = basalt_engine_get_config(es, 4);
    if v4 == expected_kv { println("  PASS: config[4] n_kv_heads = {}", v4); }
    else { println("  FAIL: config[4] n_kv_heads = {} (expected {})", v4, expected_kv); failed = 1; }

    let v5 = basalt_engine_get_config(es, 5);
    if v5 == expected_vocab { println("  PASS: config[5] vocab_size = {}", v5); }
    else { println("  FAIL: config[5] vocab_size = {} (expected {})", v5, expected_vocab); failed = 1; }

    let v6 = basalt_engine_get_config(es, 6);
    if v6 == expected_seq { println("  PASS: config[6] seq_len = {}", v6); }
    else { println("  FAIL: config[6] seq_len = {} (expected {})", v6, expected_seq); failed = 1; }

    // Invalid param_id should return -1
    let v_bad = basalt_engine_get_config(es, 99);
    if v_bad == -1 { println("  PASS: config[99] invalid = -1"); }
    else { println("  FAIL: config[99] invalid = {} (expected -1)", v_bad); failed = 1; }

    // ── Test 3: basalt_ingest_prompt (bulk prefill) ─────────────────────
    println("TEST 3: basalt_engine_ingest_prompt (bulk, 3 tokens)...");

    // Stack-allocated token array (avoids Z3 ownership trap at malloc boundary)
    let prompt_tokens: [i64; 8] = [2, 5, 3, 0, 0, 0, 0, 0];
    let tokens_ptr = prompt_tokens as Ptr<i64>;

    // Bulk ingest: should run 3 forward passes internally
    basalt_engine_ingest_prompt(es, tokens_ptr, 3);

    println("  PASS: ingest_prompt completed without crash");

    // After ingesting 3 tokens, pos should be 3 (prefill used positions 0,1,2)

    // ── Test 4: Generate after bulk prefill ──────────────────────────────
    println("TEST 4: basalt_engine_generate_step after ingest...");
    let token1 = basalt_engine_generate_step(es);
    if token1 >= 0 {
        println("  PASS: first generated token = {} (valid)", token1);
    } else {
        println("  FAIL: first generated token = {} (expected >= 0)", token1);
        failed = 1;
    }

    // Generate a few more tokens (seq_len=8, pos=4 after first gen)
    let token2 = basalt_engine_generate_step(es);
    let token3 = basalt_engine_generate_step(es);
    let token4 = basalt_engine_generate_step(es);
    let token5 = basalt_engine_generate_step(es);
    println("  tokens: {}, {}, {}, {}", token2, token3, token4, token5);

    // pos=8 now (3 prefill + 5 gen). Next should hit seq_len=8, return -1
    let token_end = basalt_engine_generate_step(es);
    if token_end == -1 {
        println("  PASS: generate stops at seq_len (returns -1)");
    } else {
        println("  FAIL: should stop at seq_len, got {}", token_end);
        failed = 1;
    }

    // ── Test 5: Free ────────────────────────────────────────────────────
    println("TEST 5: basalt_engine_free...");
    basalt_engine_free(es);
    println("  PASS: free completed without crash");

    // ── Test 6: Null safety ─────────────────────────────────────────────
    println("TEST 6: null pointer safety...");
    let null_gen = basalt_engine_generate_step(0 as Ptr<u8>);
    if null_gen == -1 { println("  PASS: generate(null) = -1"); }
    else { println("  FAIL: generate(null) = {}", null_gen); failed = 1; }

    let null_cfg = basalt_engine_get_config(0 as Ptr<u8>, 0);
    if null_cfg == -1 { println("  PASS: get_config(null, 0) = -1"); }
    else { println("  FAIL: get_config(null, 0) = {}", null_cfg); failed = 1; }

    // Ingest with null es_ptr and count=0 should not crash
    let dummy_toks: [i64; 8] = [0, 0, 0, 0, 0, 0, 0, 0];
    basalt_engine_ingest_prompt(0 as Ptr<u8>, dummy_toks as Ptr<i64>, 0);
    println("  PASS: ingest_prompt(null) no crash");

    // ── Test 7: Re-init + ingest + generate cycle ───────────────────────
    println("TEST 7: full re-init cycle...");
    let es2 = basalt_engine_init(model, 0);
    if (es2 as i64) == 0 { println("  FAIL: re-init returned null"); failed = 1; }

    // Ingest 2 tokens, generate 1
    let prompt2: [i64; 8] = [1, 4, 0, 0, 0, 0, 0, 0];
    let tokens_ptr2 = prompt2 as Ptr<i64>;
    basalt_engine_ingest_prompt(es2, tokens_ptr2, 2);

    let gen_after_reinit = basalt_engine_generate_step(es2);
    if gen_after_reinit >= 0 {
        println("  PASS: generate after re-init+ingest = {}", gen_after_reinit);
    } else {
        println("  FAIL: generate after re-init+ingest = {}", gen_after_reinit);
        failed = 1;
    }
    basalt_engine_free(es2);

    free(model);

    // ── Summary ─────────────────────────────────────────────────────────
    println("");
    if failed == 0 {
        println("ALL 7 BRUTALIST API TESTS PASSED");
    } else {
        println("SOME TESTS FAILED");
    }
    return failed;
}
