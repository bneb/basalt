// Test: Basalt E2E — Full Stack Hardware Convergence
//
//   1. Mock syscall → retrieve physical BAR addresses
//   2. Construct tensors over hardware-backed memory
//   3. Initialize: A=1.0 (NVMe), B=2.0 (RDMA), C=0.0 (Arena)
//   4. Execute hardware-routed 4×4 matmul with for-loop reduction
//   5. Verify: each C[i,j] = 4 × 1.0 × 2.0 = 8.0
//
// This test uses malloc'd memory to simulate the physical BARs.
// On bare-metal KeuOS, these would be actual MMIO regions.
//
// Exit codes:
//   0 = all passed (Convergence achieved)
//   1 = allocation failure
//   2 = mock syscall returned wrong NVMe BAR
//   3 = mock syscall returned wrong RDMA BAR
//   4 = mock syscall returned wrong Arena BAR
//   5 = invalid capability did not return 0
//   6 = C[0,0] incorrect
//   7 = C[1,1] incorrect
//   8 = C[3,3] incorrect
//   9 = C[2,1] incorrect (off-diagonal)
//  10 = hardware inference failed
// =============================================================================

package main

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn free(ptr: u64);

// ============================================================================
// Inline mock syscall (matches capability.salt)
// ============================================================================
const SYSCALL_CAP_BIND: u64 = 101;

fn mock_syscall(syscall_num: u64, arg0: u64) -> u64 {
    if syscall_num == SYSCALL_CAP_BIND {
        if arg0 == 0 { return 0x00000003E0000000; }
        if arg0 == 1 { return 0x00000005C0000000; }
        if arg0 == 2 { return 0x0000000100000000; }
    }
    return 0;
}

fn request_hardware_capability(cap_id: u32) -> u64 {
    return mock_syscall(SYSCALL_CAP_BIND, cap_id as u64);
}

// ============================================================================
// Inline convergence app (matches app_hw_matmul.salt)
// ============================================================================
fn execute_hardware_inference(
    nvme_addr: u64,
    rdma_addr: u64,
    arena_addr: u64
) -> u32 {
    // Initialize tensors
    let mut idx: u32 = 0;
    while idx < 16 {
        let off: u64 = (idx as u64) * 8;
        *((nvme_addr + off) as &mut f64) = 1.0;
        *((rdma_addr + off) as &mut f64) = 2.0;
        *((arena_addr + off) as &mut f64) = 0.0;
        idx = idx + 1;
    }

    // Hardware-routed matmul (for-loop, reduction in inner loop)
    for i in 0..4 {
        for j in 0..4 {
            let mut sum: f64 = 0.0;
            for k in 0..4 {
                let a_off: u64 = ((i * 4 + k) as u64) * 8;
                let a_val: f64 = *((nvme_addr + a_off) as &f64);

                let b_off: u64 = ((k * 4 + j) as u64) * 8;
                let b_val: f64 = *((rdma_addr + b_off) as &f64);

                sum = sum + (a_val * b_val);
            }

            let c_off: u64 = ((i * 4 + j) as u64) * 8;
            *((arena_addr + c_off) as &mut f64) = sum;
        }
    }

    return 1;
}

fn main() -> i32 {
    // =========================================================================
    // T1: Verify mock syscall returns expected BAR addresses
    // =========================================================================
    let nvme_bar: u64 = request_hardware_capability(0);
    if nvme_bar != 0x00000003E0000000 {
        return 2;
    }

    let rdma_bar: u64 = request_hardware_capability(1);
    if rdma_bar != 0x00000005C0000000 {
        return 3;
    }

    let arena_bar: u64 = request_hardware_capability(2);
    if arena_bar != 0x0000000100000000 {
        return 4;
    }

    // T2: Invalid capability returns 0
    let invalid: u64 = request_hardware_capability(99);
    if invalid != 0 {
        return 5;
    }

    // =========================================================================
    // T3: Full E2E — Allocate tensor memory, run inference, verify output
    // =========================================================================
    // In this test, we use malloc to simulate the BAR-backed memory.
    // On bare-metal, these addresses would be physical BAR regions.
    let mat_size: i64 = 128;  // 4×4 × 8 bytes per f64

    let a_addr: u64 = malloc(mat_size) as u64;
    let b_addr: u64 = malloc(mat_size) as u64;
    let c_addr: u64 = malloc(mat_size) as u64;

    if a_addr == 0 { return 1; }
    if b_addr == 0 { free(a_addr); return 1; }
    if c_addr == 0 { free(a_addr); free(b_addr); return 1; }

    // Execute the convergence application
    let result: u32 = execute_hardware_inference(a_addr, b_addr, c_addr);
    if result != 1 {
        free(a_addr);
        free(b_addr);
        free(c_addr);
        return 10;
    }

    // =========================================================================
    // T4: Verify matmul output — each C[i,j] = 4 × 1.0 × 2.0 = 8.0
    // =========================================================================

    // C[0,0] — offset 0
    let c00: f64 = *((c_addr) as &f64);
    if c00 > 8.1 { free(a_addr); free(b_addr); free(c_addr); return 6; }
    if c00 < 7.9 { free(a_addr); free(b_addr); free(c_addr); return 6; }

    // C[1,1] — offset = (1*4+1)*8 = 40
    let c11: f64 = *((c_addr + 40) as &f64);
    if c11 > 8.1 { free(a_addr); free(b_addr); free(c_addr); return 7; }
    if c11 < 7.9 { free(a_addr); free(b_addr); free(c_addr); return 7; }

    // C[3,3] — offset = (3*4+3)*8 = 120
    let c33: f64 = *((c_addr + 120) as &f64);
    if c33 > 8.1 { free(a_addr); free(b_addr); free(c_addr); return 8; }
    if c33 < 7.9 { free(a_addr); free(b_addr); free(c_addr); return 8; }

    // C[2,1] — offset = (2*4+1)*8 = 72  (off-diagonal)
    let c21: f64 = *((c_addr + 72) as &f64);
    if c21 > 8.1 { free(a_addr); free(b_addr); free(c_addr); return 9; }
    if c21 < 7.9 { free(a_addr); free(b_addr); free(c_addr); return 9; }

    // =========================================================================
    // CONVERGENCE ACHIEVED
    // =========================================================================
    free(a_addr);
    free(b_addr);
    free(c_addr);
    return 0;
}
