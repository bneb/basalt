// =============================================================================
// Test: basalt.kernels — Z3-Verified Compute Kernels
// =============================================================================
// Tests rmsnorm, softmax, and matmul against known golden values.
// Uses exit codes for assertion (0 = PASS, non-zero = specific failure).
// =============================================================================

package main

extern fn malloc(size: i64) -> Ptr<u8>;
extern fn expf(x: f32) -> f32;
extern fn sqrtf(x: f32) -> f32;

// ---- Utility ----

fn alloc_f32(count: i64) -> Ptr<f32> {
    let ptr: Ptr<u8> = malloc(count * 4);
    return ptr as Ptr<f32>;
}

fn approx_eq(a: f32, b: f32, tol: f32) -> bool {
    let diff = a - b;
    let abs_diff = if diff > 0.0f32 { diff } else { 0.0f32 - diff };
    return abs_diff < tol;
}

// ---- Kernels Under Test (inlined for standalone compilation) ----

fn rmsnorm(out: Ptr<f32>, x: Ptr<f32>, weight: Ptr<f32>, size: i64)
    requires size > 0
{
    let mut ss: f32 = 0.0f32;
    for i in 0..size {
        let v: f32 = x[i];
        ss = ss + v * v;
    }
    ss = ss / (size as f32);
    ss = ss + 0.00001f32;
    ss = 1.0f32 / sqrtf(ss);
    for i in 0..size {
        let w: f32 = weight[i];
        let v: f32 = x[i];
        out[i] = w * (ss * v);
    }
}

fn softmax(x: Ptr<f32>, size: i64)
    requires size > 0
{
    let mut max_val: f32 = x[0];
    for i in 1..size {
        if x[i] > max_val {
            max_val = x[i];
        }
    }
    let mut sum: f32 = 0.0f32;
    for i in 0..size {
        let val: f32 = expf(x[i] - max_val);
        x[i] = val;
        sum = sum + val;
    }
    for i in 0..size {
        let v: f32 = x[i];
        x[i] = v / sum;
    }
}

fn mat_mul(out: Ptr<f32>, a: Ptr<f32>, b: Ptr<f32>, m: i64, n: i64, d: i64)
    requires m > 0
    requires n > 0
    requires d > 0
{
    for i in 0..m {
        for j in 0..n {
            let mut sum: f32 = 0.0f32;
            for k in 0..d {
                let av: f32 = a[i * d + k];
                let bv: f32 = b[k * n + j];
                sum = sum + av * bv;
            }
            out[i * n + j] = sum;
        }
    }
}

// ---- Test Cases ----

fn test_rmsnorm() -> i32 {
    let size: i64 = 4;
    let x = alloc_f32(size);
    let out = alloc_f32(size);
    let weight = alloc_f32(size);

    x[0] = 1.0f32;
    x[1] = 2.0f32;
    x[2] = 3.0f32;
    x[3] = 4.0f32;

    weight[0] = 1.0f32;
    weight[1] = 1.0f32;
    weight[2] = 1.0f32;
    weight[3] = 1.0f32;

    rmsnorm(out, x, weight, size);

    // RMS = sqrt((1+4+9+16)/4) = sqrt(7.5), ss = 1/sqrt(7.5+1e-5) ≈ 0.36515
    if !approx_eq(out[0], 0.3651f32, 0.01f32) { return 101; }
    if !approx_eq(out[1], 0.7303f32, 0.01f32) { return 102; }
    if !approx_eq(out[2], 1.0954f32, 0.01f32) { return 103; }
    if !approx_eq(out[3], 1.4606f32, 0.01f32) { return 104; }

    // Non-unit weights
    weight[0] = 2.0f32;
    weight[1] = 0.5f32;
    rmsnorm(out, x, weight, size);
    if !approx_eq(out[0], 0.7303f32, 0.01f32) { return 105; }
    if !approx_eq(out[1], 0.3651f32, 0.01f32) { return 106; }

    return 0;
}

fn test_softmax() -> i32 {
    let size: i64 = 3;
    let x = alloc_f32(size);

    x[0] = 1.0f32;
    x[1] = 2.0f32;
    x[2] = 3.0f32;

    softmax(x, size);

    // Verify sum ≈ 1.0
    let sum: f32 = x[0] + x[1] + x[2];
    if !approx_eq(sum, 1.0f32, 0.001f32) { return 201; }

    // Verify monotonicity
    if x[0] > x[1] { return 202; }
    if x[1] > x[2] { return 203; }

    // Known values: softmax([1,2,3]) ≈ [0.0900, 0.2447, 0.6652]
    if !approx_eq(x[0], 0.0900f32, 0.01f32) { return 204; }
    if !approx_eq(x[1], 0.2447f32, 0.01f32) { return 205; }
    if !approx_eq(x[2], 0.6652f32, 0.01f32) { return 206; }

    // Numerical stability: large values
    let big = alloc_f32(3);
    big[0] = 1000.0f32;
    big[1] = 1001.0f32;
    big[2] = 1002.0f32;
    softmax(big, 3);
    let big_sum: f32 = big[0] + big[1] + big[2];
    if !approx_eq(big_sum, 1.0f32, 0.001f32) { return 207; }

    return 0;
}

fn test_mat_mul() -> i32 {
    // A: 2x3, B: 3x2, out: 2x2
    // A = [[1,2,3],[4,5,6]]  B = [[7,8],[9,10],[11,12]]
    // out = [[58,64],[139,154]]
    let m: i64 = 2;
    let d: i64 = 3;
    let n: i64 = 2;

    let a = alloc_f32(m * d);
    let b = alloc_f32(d * n);
    let out = alloc_f32(m * n);

    a[0] = 1.0f32;  a[1] = 2.0f32;  a[2] = 3.0f32;
    a[3] = 4.0f32;  a[4] = 5.0f32;  a[5] = 6.0f32;

    b[0] = 7.0f32;  b[1] = 8.0f32;
    b[2] = 9.0f32;  b[3] = 10.0f32;
    b[4] = 11.0f32; b[5] = 12.0f32;

    mat_mul(out, a, b, m, n, d);

    if !approx_eq(out[0], 58.0f32, 0.01f32) { return 301; }
    if !approx_eq(out[1], 64.0f32, 0.01f32) { return 302; }
    if !approx_eq(out[2], 139.0f32, 0.01f32) { return 303; }
    if !approx_eq(out[3], 154.0f32, 0.01f32) { return 304; }

    // Edge case: 1x1 matmul
    let a1 = alloc_f32(1);
    let b1 = alloc_f32(1);
    let o1 = alloc_f32(1);
    a1[0] = 3.0f32;
    b1[0] = 7.0f32;
    mat_mul(o1, a1, b1, 1, 1, 1);
    if !approx_eq(o1[0], 21.0f32, 0.01f32) { return 305; }

    return 0;
}

fn main() -> i32 {
    let r1: i32 = test_rmsnorm();
    if r1 != 0 {
        println(f"FAIL: test_rmsnorm (code {r1})");
        return r1;
    }
    println("  ✓ rmsnorm");

    let r2: i32 = test_softmax();
    if r2 != 0 {
        println(f"FAIL: test_softmax (code {r2})");
        return r2;
    }
    println("  ✓ softmax");

    let r3: i32 = test_mat_mul();
    if r3 != 0 {
        println(f"FAIL: test_mat_mul (code {r3})");
        return r3;
    }
    println("  ✓ mat_mul");

    println("basalt kernels: PASS");
    return 0;
}
